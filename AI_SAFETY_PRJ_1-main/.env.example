APP_NAME=AI Smart Safety MVP - Python Detector
APP_ENV=dev
APP_TIMEZONE=Asia/Seoul
DATA_DIR=./data
MODELS_DIR=./models
SNAPSHOT_DIR=./data/snapshots
SQLITE_PATH=./data/events.db
OUTBOX_JSONL=./data/outbox/events.jsonl
# false면 HTTP 전송을 비활성하고 outbox 큐에만 적재합니다.
TEMP_UPLOAD_DIR=./data/uploads
SPRING_BOOT_EVENT_URL=
SPRING_BOOT_DELIVERY_ENABLED=true
SPRING_BOOT_SLEEP_SETTING_URL=
HTTP_TIMEOUT_SECONDS=5.0
# 단일 이벤트 전송 시 내부 재시도 횟수
RETRY_MAX_ATTEMPTS=3
# 재시도 간 고정 backoff(초)
RETRY_BACKOFF_SECONDS=1.5
SAMPLE_FPS=5.0
REALTIME_EVENT_LOG_PATH=./data/realtime_events.jsonl
REALTIME_RECENT_EVENT_LIMIT=6
REALTIME_RECENT_EVENT_MAX_LIMIT=20
REALTIME_MJPEG_BOUNDARY=frame
REALTIME_WEBCAM_SOURCE=0
REALTIME_WEBCAM_WIDTH=960
REALTIME_WEBCAM_HEIGHT=540
REALTIME_WEBCAM_FPS=15.0
REALTIME_WEBCAM_BACKEND=
REALTIME_VIOLENCE_MOTION_THRESHOLD=0.025
REALTIME_VIOLENCE_PAIR_DISTANCE_THRESHOLD=220.0
REALTIME_VIOLENCE_HOLD_SECONDS=2.0
REALTIME_NOTIFY_ENABLED=false
REALTIME_NOTIFY_EVENT_TYPES=fall,inactive
REALTIME_NOTIFY_RESIDENT_ID=1
# 실시간 알림 스냅샷 저장 경로(현재는 단일 resident_id 고정 매핑 기반)
REALTIME_SNAPSHOT_DIR=./data/snapshots/realtime
FALL_ENABLED=true
FALL_POSE_TASK_MODEL_PATH=./models/pose_landmarker.task
FALL_HOLD_SECONDS=5.0
FALL_ANGLE_THRESHOLD_DEG=60.0
FALL_MIN_VISIBILITY=0.4
FALL_MIN_POSE_DETECTION_CONFIDENCE=0.5
FALL_MIN_POSE_PRESENCE_CONFIDENCE=0.5
FALL_MIN_TRACKING_CONFIDENCE=0.5
FALL_ENABLE_HOG_FALLBACK=true
FALL_HOG_ASPECT_RATIO_THRESHOLD=1.15
INACTIVE_SECONDS=30.0
MOTION_THRESHOLD=0.002
ENABLE_YOLO_PERSON_GATE=false
YOLO_MODEL=yolov8n.pt
NO_EVENT_COOLDOWN_SECONDS=20.0
SNAPSHOT_EXPIRE_DAYS=7
